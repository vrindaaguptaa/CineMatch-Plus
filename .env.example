# Required for MongoDB-backed authentication. Prefer the full Atlas URI.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/MovieRS?retryWrites=true&w=majority

# Required in production: use a long, random value and keep it secret.
SESSION_SECRET_KEY=replace-with-a-long-random-secret

# Set to true when the deployed site is served over HTTPS (recommended).
SESSION_COOKIE_SECURE=true

# Required for TMDB-powered discovery, autocomplete, posters, and details.
TMDB_API_KEY=

# Optional when the browser is hosted on a different origin. Separate multiple
# origins with commas; leave unset when Flask serves the browser itself.
FRONTEND_URL=

# Local troubleshooting only. Never enable this in production.
FLASK_DEBUG=false
